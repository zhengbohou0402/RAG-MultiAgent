# DashScope
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
CHAT_MODEL_NAME=qwen-turbo
EMBEDDING_MODEL_NAME=text-embedding-v3

# Local services
SERVER_ADDRESS=127.0.0.1
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_USE_TLS=false
QDRANT_API_KEY=
QDRANT_AUTO_START=true
QDRANT_LOCAL_EXECUTABLE=qdrant_local/qdrant.exe
QDRANT_LOCAL_STORAGE=qdrant_local/storage
LEXICAL_INDEX_PATH=lucene_local

# Crawler
CRAWLER_ENABLED=false
CRAWLER_INTERVAL_HOURS=168
CRAWLER_MAX_PAGES=80
CRAWLER_BROWSER_ENABLED=true
CRAWLER_BROWSER_AUTO_DOWNLOAD=false
CRAWLER_STATIC_FALLBACK=true
CRAWLER_STATIC_TLS_FALLBACK=true
CRAWLER_HEADLESS=true
CRAWLER_PAGE_TIMEOUT_SECONDS=40
CRAWLER_PAGE_DELAY_MILLIS=800
CRAWLER_MIN_CONTENT_CHARS=200
CRAWLER_MAX_QUEUED_LINKS=2000

# SmartCloud industrial demo infrastructure
SMARTCLOUD_SQL_ENABLED=true
SMARTCLOUD_MONGO_ENABLED=true
SMARTCLOUD_REDIS_ENABLED=true
SMARTCLOUD_DEFAULT_TENANT=tenant-demo
SMARTCLOUD_DEFAULT_USER=demo-admin
SMARTCLOUD_JWT_SECRET=smartcloud-local-demo-secret-change-me-please
SMARTCLOUD_TOKEN_TTL_MINUTES=720

# Docker Compose service credentials
MYSQL_DATABASE=smartcloud
MYSQL_USER=smartcloud
MYSQL_PASSWORD=smartcloud123
MYSQL_ROOT_PASSWORD=root123456
MYSQL_R2DBC_URL=r2dbc:mysql://localhost:3306/smartcloud
MYSQL_JDBC_URL=jdbc:mysql://localhost:3306/smartcloud?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
MONGO_INITDB_ROOT_USERNAME=smartcloud
MONGO_INITDB_ROOT_PASSWORD=smartcloud123
MONGO_URI=mongodb://smartcloud:smartcloud123@localhost:27017/smartcloud?authSource=admin
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Local protocol endpoints
SMARTCLOUD_MCP_ENDPOINT=http://127.0.0.1:8000/mcp
SMARTCLOUD_A2A_ENDPOINT=http://127.0.0.1:8000
SMARTCLOUD_MARKETING_ASSETS_PATH=data/smartcloud/assets
