{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SmartCloud ServiceOps",
  "version": "0.2.0",
  "identifier": "com.smartcloud.serviceops",
  "build": {
    "frontendDist": "../../src/main/resources/static",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SmartCloud ServiceOps",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "tooltip": "SmartCloud ServiceOps",
      "showMenuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false,
    "resources": ["java-backend/**/*"],
    "windows": {
      "nsis": {
        "installMode": "both",
        "installerIcon": "icons/icon.ico",
        "languages": ["English", "SimpChinese"],
        "displayLanguageSelector": true,
        "compression": "lzma",
        "startMenuFolder": "SmartCloud ServiceOps"
      }
    }
  },
  "plugins": {}
}
